generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Loan {
  id             String   @id @default(uuid())
  onChainId      String   @default(uuid())
  borrowerUnlink String
  creditScore    Int
  amount         String
  collateral     String
  duration       Int
  deadline       DateTime
  maxRate        Float
  status         String   @default("OPEN")
  createdAt      DateTime @default(now())
  bids           Bid[]
}

model Bid {
  id           String   @id @default(uuid())
  loanId       String
  loan         Loan     @relation(fields: [loanId], references: [id])
  lenderUnlink String
  amount       String
  rate         Float
  status       String   @default("PENDING")
  submittedAt  DateTime @default(now())
  paid         Boolean  @default(false)
  paidAmount   String   @default("0")
  paymentRelay  String?

  @@index([loanId, rate])
}

model CreditProfile {
  id             String   @id @default(uuid())
  unlinkAddress  String   @unique
  walletAddress  String?
  creditScore    Int
  declaredIncome Int
  createdAt      DateTime @default(now())
}